# ==========================================
# Telegram Bot Configuration
# ==========================================
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij
ADMIN_GROUP_ID=-1004452282696
ORDER_TOPIC_ID=1
TICKET_TOPIC_ID=8
PAYMENT_TOPIC_ID=10

# Application routing and versioning
MINI_APP_URL=https://nitrobot.duckdns.org
DOMAIN_NAME=nitrobot.duckdns.org
APP_VERSION=2026-07-06-producers-convert-v5

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql+asyncpg://nitro_user:secure_password_here@db:5432/nitrodb
POSTGRES_USER=nitro_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=nitrodb

# ==========================================
# Object Storage Configuration (MinIO / S3)
# ==========================================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=admin_access_key
S3_SECRET_KEY=super_secure_secret_key_here
S3_BUCKET=nitro-bot

# ==========================================
# Internal API Security & Authentication
# ==========================================
SELENIUM_SECRET_KEY=YOUR_SECURE_GENERATED_SELENIUM_TOKEN
SKIP_TELEGRAM_AUTH=true

# ==========================================
# Kontor DMB Automation Worker
# ==========================================
DMB_USERNAME=your_dmb_username
DMB_PASSWORD=your_dmb_password
POLL_INTERVAL=30
DRY_RUN=false

# ==========================================
# Exchange Rates & APIs
# ==========================================
USDT_RATE_URL=https://api.nobitex.ir/market/stats?srcCurrency=usdt&dstCurrency=rls
USDT_TOMAN_FALLBACK=0

# ==========================================
# Frontend Build Variables
# ==========================================
VITE_API_URL=https://nitrobot.duckdns.org