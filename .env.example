# ==========================================
# Telegram Bot Configuration
# ==========================================
# Your bot token obtained from @BotFather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij

# The Telegram supergroup ID where admin notifications are sent.
# For a supergroup, prefix the internal group id with -100
# (e.g. group 4452282696 -> -1004452282696).
ADMIN_GROUP_ID=-1004452282696

# Forum topic IDs (message_thread_id) inside the admin supergroup.
# Leave blank to post into the group's General topic.
ORDER_TOPIC_ID=1
TICKET_TOPIC_ID=8
PAYMENT_TOPIC_ID=10

# Live USDT/Toman rate proxy (crypto top-up calculator).
# USDT_RATE_URL: exchange endpoint returning stats.usdt-rls.latest in Rials.
# USDT_TOMAN_FALLBACK: manual Toman rate used only when the exchange is
# unreachable and nothing is cached (0 = disabled, endpoint returns 503).
USDT_RATE_URL=https://api.nobitex.ir/market/stats?srcCurrency=usdt&dstCurrency=rls
USDT_TOMAN_FALLBACK=0

# The HTTPS URL of your deployed Mini App (used for the /start inline button)
MINI_APP_URL=https://nitrobot.duckdns.org
DOMAIN_NAME=nitrobot.duckdns.org

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# Primary database connection string for FastAPI/SQLAlchemy
DATABASE_URL=postgresql+asyncpg://nitro_user:secure_password_here@db:5432/nitrodb

# Credentials used by the Postgres Docker container to initialize the DB
POSTGRES_USER=nitro_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=nitrodb

# ==========================================
# Object Storage Configuration (MinIO / S3)
# ==========================================
# Internal Docker network endpoint for MinIO
S3_ENDPOINT=http://minio:9000

# Public browser-facing MinIO/S3 endpoint used in presigned URLs
S3_PUBLIC_ENDPOINT=https://nitrobot.duckdns.org

# MinIO root user (acts as AWS Access Key)
S3_ACCESS_KEY=admin_access_key

# MinIO root password (acts as AWS Secret Key)
S3_SECRET_KEY=super_secure_secret_key_here

# ==========================================
# Internal API Security
# ==========================================
# The Bearer token your future Python Selenium bot will use to authenticate
SELENIUM_SECRET_KEY=YOUR_SECURE_GENERATED_SELENIUM_TOKEN

# Set to 'true' for local development only — disables Telegram auth validation
SKIP_TELEGRAM_AUTH=false
