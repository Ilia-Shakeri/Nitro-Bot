{$DOMAIN_NAME} {
    @api {
        path /users/* /releases/* /transactions/* /internal/*
    }
    handle @api {
        reverse_proxy backend:8000 {
            # Pass the real client IP so backend rate limiting works correctly
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle {
        reverse_proxy frontend:80
    }
}
