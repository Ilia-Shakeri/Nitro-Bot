nitrobot.duckdns.org {
    # Encode responses with gzip/zstd for better performance
    encode zstd gzip

    # Route FastAPI backend endpoints
    handle /users* {
        reverse_proxy backend:8000
    }
    
    handle /releases* {
        reverse_proxy backend:8000
    }
    
    handle /transactions* {
        reverse_proxy backend:8000
    }

    # Route everything else to the Vite/Nginx frontend on port 80
    handle {
        reverse_proxy frontend:80
    }
}