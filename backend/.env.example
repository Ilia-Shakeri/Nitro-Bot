# Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_GROUP_ID=-1002345678901
MINI_APP_URL=https://your-app.com

# Topic IDs (from t.me/c/GROUPID/TOPICID format)
# Order Topic: https://t.me/c/4452282696/1
ORDER_TOPIC_ID=1

# Payment Topic: https://t.me/c/4452282696/10
PAYMENT_TOPIC_ID=10

# Ticket Topic: https://t.me/c/4452282696/8
TICKET_TOPIC_ID=8

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/nitrodb

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET=nitro-bot

# Skip auth for local dev (set to "true" for dev, remove for production)
SKIP_TELEGRAM_AUTH=false
